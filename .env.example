# Body Shaper System™ — environment variables
#
# Copy this file to .env.local (for local dev) and set the real
# values there. .env.local is gitignored and never committed.
# The same variable names must also be added in Vercel's Project
# Settings -> Environment Variables for production/preview deploys.

# --- Supabase ---
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings -> API -> "service_role" key. SECRET — server-only,
# bypasses Row Level Security. Never expose to the browser, never
# prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Prisma) ---
# Project Settings -> Database -> Connection string, in Supabase.
# DATABASE_URL: the pooled "Transaction" mode string (port 6543) —
#   used at runtime by the app.
# DIRECT_URL: the direct connection string (port 5432) — used only
#   when running Prisma migrations, since PgBouncer's transaction
#   pooling mode doesn't support the prepared statements migrations need.
DATABASE_URL=
DIRECT_URL=
