// Prisma schema — Body Shaper System™ BSS Hub
// Milestone 1: core database architecture, role system, leads module.
//
// Connection strategy (Supabase + Prisma + Vercel serverless):
// - DATABASE_URL  -> Supabase's pooled "Transaction" connection string
//                    (port 6543, via PgBouncer) — used at runtime.
// - DIRECT_URL    -> Supabase's direct/session connection string
//                    (port 5432) — used only for running migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Roles & Permissions ----------
// Permissions are NEVER hardcoded in application code. A role is just
// a named bucket of permissions; granting/revoking access to a
// feature means adding/removing rows here, not shipping new code.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "Owner", "Admin", "Manager", "Specialist", "Assistant", "Marketing", "Client"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "leads.view", "leads.edit", "leads.delete", "clients.view"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ---------- Users (Hub staff + portal clients, one identity system) ----------
// `authUserId` links to Supabase Auth's own user (auth.users.id), which
// owns the actual password/session. This table is BSS's own profile +
// role/permission layer on top of that identity.

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

// Only meaningful for Client-role users (Hub staff leave this null).
enum PortalStatus {
  NOT_CREATED
  INVITATION_PENDING
  INVITATION_SENT
  ACTIVE
  INVITATION_EXPIRED
  SUSPENDED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  authUserId   String        @unique // Supabase Auth user id (auth.users.id)
  email        String        @unique
  fullName     String
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  status       UserStatus    @default(ACTIVE)
  portalStatus PortalStatus? // Client-role users only

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  lastLoginAt DateTime?

  leadsCreated      Lead[]              @relation("LeadCreatedBy")
  leadStatusChanges LeadStatusHistory[]
  clientRecord      Client?

  @@map("users")
}

// ---------- Leads ----------
// Every website lead lands here first. Leads do NOT get portal access.
// Nothing is ever hard-deleted — archivedAt marks a soft delete/archive.

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONSULTATION_SCHEDULED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  CONVERTED
  LOST
  ARCHIVED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  REFUNDED
}

model Lead {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  city      String?
  goals     String?
  source    String? // e.g. "website", "instagram", "referral", "jotform:lets-build-your-blueprint"

  status        LeadStatus    @default(NEW)
  paymentStatus PaymentStatus @default(NOT_REQUIRED)
  timeline      String? // client's stated timeline/urgency, free text for now

  internalNotes String?
  bodyBlueprint Json? // raw Body Blueprint™ submission data, if submitted as a lead

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  createdBy   User?     @relation("LeadCreatedBy", fields: [createdById], references: [id])
  archivedAt  DateTime? // soft delete — never hard-delete lead data

  // Set once, by the idempotent Lead -> Client conversion action.
  // The FK lives on Client (clients.leadId, unique) — a lead can
  // never convert into more than one Client record. This is just the
  // convenience reverse-lookup + a timestamp of when it happened.
  convertedClient Client?
  convertedAt     DateTime?

  statusHistory LeadStatusHistory[]
  emailHistory  LeadEmailLog[]
  emailEvents   EmailEvent[]

  @@map("leads")
}

model LeadStatusHistory {
  id          String      @id @default(cuid())
  leadId      String
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus  LeadStatus?
  toStatus    LeadStatus
  note        String?
  changedAt   DateTime    @default(now())
  changedById String?
  changedBy   User?       @relation(fields: [changedById], references: [id])

  @@map("lead_status_history")
}

// Structure only for now — actual sending is Phase 1 Milestone 6
// (Resend automation). This just gives every lead a permanent,
// queryable email timeline from day one.
model LeadEmailLog {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject     String
  sentAt      DateTime @default(now())
  sequenceKey String? // maps to EMAIL_SEQUENCE keys in src/lib/email-sequence.ts

  @@map("lead_email_log")
}

// ---------- Clients (Milestone 2) ----------
// Created exactly once per person via the idempotent Lead -> Client
// conversion. Never a duplicate person record: leadId and userId are
// both unique, so a lead can convert at most once, and a portal auth
// identity backs at most one client.

model Client {
  id             String  @id @default(cuid())
  leadId         String  @unique
  lead           Lead    @relation(fields: [leadId], references: [id])
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  email          String
  phone          String?
  city           String?
  membershipTier String  @default("Standard")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  archivedAt  DateTime?

  bodyBlueprints BodyBlueprint[]
  measurements   Measurement[]
  documents      Document[]
  messageThread  MessageThread?
  rewardsAccount RewardsAccount?
  portalInvite   PortalInvitation?
  emailEvents    EmailEvent[]

  @@map("clients")
}

// ---------- Body Blueprint (versioned, never overwritten) ----------

model BodyBlueprint {
  id                 String   @id @default(cuid())
  clientId           String
  client             Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  version            Int
  goals              String?
  treatmentInterests String?
  recommendedSystem  String?
  formAnswers        Json?
  internalNotes      String?
  createdAt          DateTime @default(now())
  createdById        String?

  @@unique([clientId, version])
  @@map("body_blueprints")
}

// ---------- Measurements (manual entry, RENPHO-shaped; historical only) ----------

model Measurement {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  scanDate         DateTime
  weightKg         Float?
  bodyFatPercent   Float?
  muscleMassKg     Float?
  bodyWaterPercent Float?
  bmi              Float?
  visceralFat      Float?
  boneMassKg       Float?
  bmr              Int?
  bodyAge          Int?
  deviceSource     String   @default("RENPHO Health")
  notes            String?
  createdAt        DateTime @default(now())
  createdById      String?

  @@map("measurements")
}

// ---------- Documents (Supabase Storage metadata) ----------

model Document {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title        String
  storagePath  String
  fileType     String?
  sizeBytes    Int?
  uploadedAt   DateTime @default(now())
  uploadedById String?

  @@map("documents")
}

// ---------- Messages (one thread per client) ----------

enum SenderType {
  OWNER
  CLIENT
}

model MessageThread {
  id        String    @id @default(cuid())
  clientId  String    @unique
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  messages  Message[]

  @@map("message_threads")
}

model Message {
  id           String        @id @default(cuid())
  threadId     String
  thread       MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType   SenderType
  senderUserId String?
  body         String
  createdAt    DateTime      @default(now())
  readAt       DateTime?

  @@map("messages")
}

// ---------- Rewards ----------

model RewardsAccount {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pointsBalance Int      @default(0)
  tier          String   @default("Standard")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("rewards_accounts")
}

// ---------- Portal activation invitations ----------

model PortalInvitation {
  id         String    @id @default(cuid())
  clientId   String    @unique
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  // Delivery tracking — lets the Hub show invite status and safely
  // support "Resend Invitation" without ever creating a duplicate
  // Auth user or Client record.
  lastSentAt    DateTime?
  attemptCount  Int       @default(0)

  @@map("portal_invitations")
}

// ---------- Email delivery log (Resend) ----------
// One row per send attempt, regardless of outcome. This is the
// permanent audit trail the Hub's "View Email Log" reads from — never
// deleted, even on failure, so support can always see what happened.

enum EmailTemplate {
  WELCOME_ACTIVATION
  BODY_BLUEPRINT_COMPLETED
  PAYMENT_CONFIRMATION
  BLUEPRINT_RECEIVED
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model EmailEvent {
  id                String        @id @default(cuid())
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId            String?
  lead              Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template          EmailTemplate
  senderEmail       String?
  recipient         String
  provider          String        @default("resend")
  providerMessageId String?
  status            EmailStatus   @default(QUEUED)
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime      @default(now())

  @@map("email_events")
}

