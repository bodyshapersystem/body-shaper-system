// Prisma schema — Body Shaper System™ BSS Hub
// Milestone 1: core database architecture, role system, leads module.
//
// Connection strategy (Supabase + Prisma + Vercel serverless):
// - DATABASE_URL  -> Supabase's pooled "Transaction" connection string
//                    (port 6543, via PgBouncer) — used at runtime.
// - DIRECT_URL    -> Supabase's direct/session connection string
//                    (port 5432) — used only for running migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Roles & Permissions ----------
// Permissions are NEVER hardcoded in application code. A role is just
// a named bucket of permissions; granting/revoking access to a
// feature means adding/removing rows here, not shipping new code.

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // "Owner", "Admin", "Manager", "Specialist", "Assistant", "Marketing", "Client"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "leads.view", "leads.edit", "leads.delete", "clients.view"
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ---------- Users (Hub staff + portal clients, one identity system) ----------
// `authUserId` links to Supabase Auth's own user (auth.users.id), which
// owns the actual password/session. This table is BSS's own profile +
// role/permission layer on top of that identity.

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

// Only meaningful for Client-role users (Hub staff leave this null).
enum PortalStatus {
  NOT_CREATED
  INVITATION_PENDING
  INVITATION_SENT
  ACTIVE
  INVITATION_EXPIRED
  SUSPENDED
  FAILED
}

model User {
  id           String        @id @default(cuid())
  authUserId   String        @unique // Supabase Auth user id (auth.users.id)
  email        String        @unique
  fullName     String
  roleId       String
  role         Role          @relation(fields: [roleId], references: [id])
  status       UserStatus    @default(ACTIVE)
  portalStatus PortalStatus? // Client-role users only

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  lastLoginAt DateTime?

  leadsCreated      Lead[]              @relation("LeadCreatedBy")
  leadStatusChanges LeadStatusHistory[]
  clientRecord      Client?

  @@map("users")
}

// ---------- Leads ----------
// Every website lead lands here first. Leads do NOT get portal access.
// Nothing is ever hard-deleted — archivedAt marks a soft delete/archive.

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  BLUEPRINT_COMPLETED
  CONSULTATION_SCHEDULED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  CONVERTED
  LOST
  ARCHIVED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  REFUNDED
}

model Lead {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  city      String?
  goals     String?
  source    String? // e.g. "website", "instagram", "referral", "jotform:lets-build-your-blueprint"

  status        LeadStatus    @default(NEW)
  paymentStatus PaymentStatus @default(NOT_REQUIRED)
  timeline      String? // client's stated timeline/urgency, free text for now

  internalNotes String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  createdBy   User?     @relation("LeadCreatedBy", fields: [createdById], references: [id])
  archivedAt  DateTime? // soft delete — never hard-delete lead data

  // Set once, by the idempotent Lead -> Client conversion action.
  // The FK lives on Client (clients.leadId, unique) — a lead can
  // never convert into more than one Client record. This is just the
  // convenience reverse-lookup + a timestamp of when it happened.
  convertedClient Client?
  convertedAt     DateTime?

  blueprintAssessment BlueprintAssessment?

  statusHistory LeadStatusHistory[]
  emailHistory  LeadEmailLog[]
  emailEvents   EmailEvent[]

  @@map("leads")
}

model LeadStatusHistory {
  id          String      @id @default(cuid())
  leadId      String
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus  LeadStatus?
  toStatus    LeadStatus
  note        String?
  changedAt   DateTime    @default(now())
  changedById String?
  changedBy   User?       @relation(fields: [changedById], references: [id])

  @@map("lead_status_history")
}

// Structure only for now — actual sending is Phase 1 Milestone 6
// (Resend automation). This just gives every lead a permanent,
// queryable email timeline from day one.
model LeadEmailLog {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject     String
  sentAt      DateTime @default(now())
  sequenceKey String? // maps to EMAIL_SEQUENCE keys in src/lib/email-sequence.ts

  @@map("lead_email_log")
}

// ---------- Clients (Milestone 2) ----------
// Created exactly once per person via the idempotent Lead -> Client
// conversion. Never a duplicate person record: leadId and userId are
// both unique, so a lead can convert at most once, and a portal auth
// identity backs at most one client.

model Client {
  id             String  @id @default(cuid())
  leadId         String  @unique
  lead           Lead    @relation(fields: [leadId], references: [id])
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id])
  firstName      String
  lastName       String
  email          String
  phone          String?
  city           String?
  membershipTier String  @default("Standard")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?
  archivedAt  DateTime?

  blueprintAssessments BlueprintAssessment[]
  bodyMeasurements     BodyMeasurement[]
  photos               Photo[]
  formSubmissions      FormSubmission[]
  progressSnapshots    ProgressSnapshot[]
  appointments   Appointment[]
  payments       Payment[]
  measurements   Measurement[]
  documents      Document[]
  messageThread  MessageThread?
  rewardsAccount RewardsAccount?
  portalInvite   PortalInvitation?
  emailEvents    EmailEvent[]

  @@map("clients")
}

// ---------- Body Blueprint (versioned, never overwritten) ----------

// ---------- Blueprint Assessment™ (clinical/strategic journey ONLY) ----------
// This is the exclusive home for: Jotform intake, professional
// assessment, body measurements, Renpho scans, photos, strategy, and
// reassessments. Administrative forms (Prepare for Your Experience,
// Treatment Waiver, etc.) live in FormSubmission instead — never here.
//
// A BlueprintAssessment starts at the Lead stage (leadId set,
// clientId null, status DRAFT) when Jotform's "Let's Build Your
// Blueprint™" is submitted. It is never duplicated during that
// pre-activation stage — @@unique([leadId]) means repeat submissions
// update the same draft row. When the Owner converts the Lead to a
// Client, this exact row is RE-LINKED (clientId set), never copied.
// Everything that happens afterward (the first appointment's photos,
// measurements, Renpho scan, strategy confirmation) enriches this
// same assessment — it does not restart the sales process or create
// a new version. A brand new version only gets created for an
// intentional future reassessment.

enum AssessmentStatus {
  DRAFT // legacy — pre-migration value, mapped to INTAKE_SUBMITTED
  ACTIVE // legacy — pre-migration value, mapped to BASELINE_PENDING
  INTAKE_SUBMITTED // Jotform received, no Client yet
  BASELINE_PENDING // Client activated, first appointment not yet done
  BASELINE_COMPLETED // measurements/composition/photos recorded
  VALIDATED // Owner/specialist confirmed the strategy
  IN_PROGRESS // active treatment underway
  COMPLETED
  SUPERSEDED // an older reassessment version, kept for history
  ARCHIVED
}

enum Visibility {
  INTERNAL_ONLY
  CLIENT_VISIBLE
}

model BlueprintAssessment {
  id       String            @id @default(cuid())
  leadId   String?           @unique
  lead     Lead?             @relation(fields: [leadId], references: [id])
  clientId String?
  client   Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  version  Int               @default(1)
  status   AssessmentStatus  @default(INTAKE_SUBMITTED)

  // Jotform intake (Let's Build Your Blueprint™)
  jotformSubmissionId String?
  jotformRawData      Json?
  intakeSubmissionDate DateTime?
  baselineAppointmentDate DateTime?

  // Strategy — original recommendation is frozen once set; validated
  // fields are what the specialist confirms/adjusts at the first
  // appointment. `recommendedSystem`/`treatmentInterests` remain the
  // live current values (unchanged mechanism from before — updated by
  // recordStrategyChange when they actually change).
  goals                    String?
  treatmentInterests       String?
  recommendedSystem        String?
  originalRecommendedSystem String? // frozen at intake — never overwritten
  planTotalCents            Int?    // the sold package's total price — set by the Owner, never hardcoded; null until entered

  initialFrequency      String?
  validatedFrequency     String?
  initialSessionCount    Int?
  validatedSessionCount  Int?
  complementarySessions  String?
  homeCareGuidance       String?
  optimizationNotes      String?

  validationNotes String?
  validatedById   String?
  validatedAt     DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  bodyMeasurements       BodyMeasurement[]
  renphoScans            Measurement[]
  photos                 Photo[]
  specialistObservations SpecialistObservation[]
  strategyChanges        StrategyChange[]
  progressSnapshots      ProgressSnapshot[]

  @@unique([clientId, version])
  @@map("blueprint_assessments")
}

// ---------- Body measurements (tape/manual — distinct from Renpho) ----------

model BodyMeasurement {
  id             String               @id @default(cuid())
  clientId       String
  client         Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assessmentId   String?
  assessment     BlueprintAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  appointmentId  String?
  appointment    Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  measuredAt     DateTime
  waistCm        Float?
  highWaistCm    Float?
  lowerAbdomenCm Float?
  hipsCm         Float?
  chestCm        Float?
  rightArmCm     Float?
  leftArmCm      Float?
  rightThighCm   Float?
  leftThighCm    Float?
  notes          String?
  createdAt      DateTime @default(now())
  specialistId   String?

  @@map("body_measurements")
}

// ---------- Photos ----------

enum PhotoType {
  FRONT
  LEFT
  RIGHT
  BACK
  DETAIL
}

model Photo {
  id            String              @id @default(cuid())
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assessmentId  String?
  assessment    BlueprintAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  appointmentId String?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  type          PhotoType
  storagePath   String
  takenAt       DateTime?
  uploadedAt    DateTime  @default(now())
  specialistId  String?
  notes         String?
  visibility    Visibility @default(INTERNAL_ONLY)

  @@map("photos")
}

// ---------- Specialist observations (append-only clinical log) ----------

model SpecialistObservation {
  id           String              @id @default(cuid())
  assessmentId String
  assessment   BlueprintAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  authorId     String?
  body         String
  visibility   Visibility @default(INTERNAL_ONLY)
  createdAt    DateTime @default(now())

  @@map("specialist_observations")
}

// ---------- Strategy changes (append-only audit trail) ----------

model StrategyChange {
  id               String              @id @default(cuid())
  assessmentId     String
  assessment       BlueprintAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  previousStrategy String?
  newStrategy      String
  reason           String?
  changedById      String?
  changedAt        DateTime @default(now())

  @@map("strategy_changes")
}

// ---------- Form Submissions (administrative documentation ONLY) ----------
// Everything a client fills out AFTER activation that isn't part of
// the clinical Blueprint journey: waivers, prep guides, consent
// updates. Deliberately generic (formType is just a string enum) so
// adding a new form later is one enum value, never a new table.

enum FormType {
  PREPARE_FOR_YOUR_EXPERIENCE
  TREATMENT_WAIVER
  // Reserved for later, per direction — add values here when needed:
  // MEDICAL_UPDATE, POST_SURGERY_UPDATE, GLP1_UPDATE, PHOTO_RELEASE,
  // CONSENT_UPDATES
}

enum FormStatus {
  PENDING
  COMPLETED
}

model FormSubmission {
  id                  String     @id @default(cuid())
  clientId            String
  client              Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  formType            FormType
  status              FormStatus @default(PENDING)
  version             Int        @default(1)
  jotformSubmissionId String?
  rawData             Json?
  completedAt         DateTime?
  createdAt           DateTime   @default(now())

  @@map("form_submissions")
}

// ---------- Measurements (manual entry, RENPHO-shaped; historical only) ----------

model Measurement {
  id                     String   @id @default(cuid())
  clientId               String
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assessmentId           String?
  assessment             BlueprintAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  appointmentId          String?
  appointment            Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  scanDate               DateTime
  weightKg               Float?
  bodyFatPercent         Float?
  muscleMassKg           Float?
  skeletalMuscleKg       Float?
  bodyWaterPercent       Float?
  proteinPercent         Float?
  bmi                    Float?
  visceralFat            Float?
  subcutaneousFatPercent Float?
  boneMassKg             Float?
  bmr                    Int?
  bodyAge                Int?
  fatFreeWeightKg        Float?
  deviceSource     String   @default("RENPHO Health")
  notes            String?
  createdAt        DateTime @default(now())
  createdById      String?

  @@map("measurements")
}

// ---------- Progress Timeline (architecture only — no UI, no calculation job yet) ----------
// A snapshot comparing two points in a client's Body Intelligence™
// history (typically baseline vs. latest). Concrete well-known deltas
// get their own columns; `metrics` is a JSON escape hatch for future
// delta types without another migration — same pattern as FormType.
// Nothing computes these automatically yet; this just gives a future
// job/report generator somewhere to write results.

model ProgressSnapshot {
  id                     String    @id @default(cuid())
  clientId               String
  client                 Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assessmentId           String?
  assessment             BlueprintAssessment? @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  baselineMeasurementId  String?
  latestMeasurementId    String?

  date                   DateTime // the point in time this snapshot represents
  weightDeltaKg          Float?
  bodyFatDeltaPercent    Float?
  visceralFatDelta       Float?
  skeletalMuscleDeltaKg  Float?
  inchesLost             Float?
  estimatedFatLossKg     Float?
  estimatedMuscleGainKg  Float?
  adherenceScore         Float? // e.g. 0-100, future adherence-tracking input
  specialistSummary      String?
  aiSummary              String? // reserved for future AI-generated summary
  metrics                Json?   // escape hatch for future delta types

  generatedAt            DateTime  @default(now()) // when this snapshot record was produced
  notes                  String?

  @@map("progress_snapshots")
}

// ---------- Documents (Supabase Storage metadata) ----------

model Document {
  id            String       @id @default(cuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  title         String
  storagePath   String
  fileType      String?
  sizeBytes     Int?
  uploadedAt    DateTime @default(now())
  uploadedById  String?

  @@map("documents")
}

// ---------- Messages (one thread per client) ----------

enum SenderType {
  OWNER
  CLIENT
}

model MessageThread {
  id        String    @id @default(cuid())
  clientId  String    @unique
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  messages  Message[]

  @@map("message_threads")
}

model Message {
  id           String        @id @default(cuid())
  threadId     String
  thread       MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderType   SenderType
  senderUserId String?
  body         String
  createdAt    DateTime      @default(now())
  readAt       DateTime?

  @@map("messages")
}

// ---------- Rewards ----------

model RewardsAccount {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pointsBalance Int      @default(0)
  tier          String   @default("Standard")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions RewardsTransaction[]

  @@map("rewards_accounts")
}

model RewardsTransaction {
  id               String         @id @default(cuid())
  rewardsAccountId String
  rewardsAccount   RewardsAccount @relation(fields: [rewardsAccountId], references: [id], onDelete: Cascade)
  points           Int
  action           String
  notes            String?
  createdAt        DateTime       @default(now())
  createdById      String?

  @@map("rewards_transactions")
}

// ---------- Appointments ----------

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id               String            @id @default(cuid())
  clientId         String
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title            String
  startsAt         DateTime
  endsAt           DateTime?
  status           AppointmentStatus @default(SCHEDULED)
  technologies     Json? // array of selected technology objects for this session
  estimatedMinutes Int?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdById      String?

  // Long-term architecture: every appointment is the permanent
  // clinical session record. Photos, Renpho scans, professional
  // measurements, payments, and documents can all optionally anchor
  // to the specific session they belong to, in addition to always
  // belonging to the client directly. No UI wires these up yet —
  // this is the data model groundwork for the client timeline/session
  // detail view that will read them later.
  photos           Photo[]
  renphoScans      Measurement[]
  bodyMeasurements BodyMeasurement[]
  payments         Payment[]
  documents        Document[]

  @@map("appointments")
}

// ---------- Payments ----------

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  OTHER
}

enum PaymentRecordStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentType {
  DEPOSIT
  INSTALLMENT
  FULL_PAYMENT
  CUSTOM_AMOUNT
  REFUND
  ADJUSTMENT
}

enum PaymentOrigin {
  CLIENT_PAYMENT
  AMBASSADOR
  INFLUENCER_COLLABORATION
  PARTNER
  INTERNAL_ADJUSTMENT
}

model Payment {
  id            String              @id @default(cuid())
  clientId      String
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointmentId String?
  appointment   Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  amountCents   Int
  method        PaymentMethod       @default(CARD)
  status        PaymentRecordStatus @default(PENDING)
  paymentType   PaymentType?
  origin        PaymentOrigin       @default(CLIENT_PAYMENT)
  reference     String?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdById   String?

  @@map("payments")
}

// ---------- Business Settings (singleton) ----------

model BusinessSettings {
  id                       String   @id @default("default")
  businessName             String   @default("Body Shaper System™")
  contactEmail             String?
  contactPhone             String?
  address                  String?
  fullPaymentDiscountCents Int? // "Exclusive Courtesy" full-balance discount — configurable, null = feature off
  updatedAt                DateTime @updatedAt

  @@map("business_settings")
}

// ---------- Portal activation invitations ----------

model PortalInvitation {
  id         String    @id @default(cuid())
  clientId   String    @unique
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  // Delivery tracking — lets the Hub show invite status and safely
  // support "Resend Invitation" without ever creating a duplicate
  // Auth user or Client record.
  lastSentAt    DateTime?
  attemptCount  Int       @default(0)

  @@map("portal_invitations")
}

// ---------- Email delivery log (Resend) ----------
// One row per send attempt, regardless of outcome. This is the
// permanent audit trail the Hub's "View Email Log" reads from — never
// deleted, even on failure, so support can always see what happened.

enum EmailTemplate {
  WELCOME_ACTIVATION
  BODY_BLUEPRINT_COMPLETED
  PAYMENT_CONFIRMATION
  BLUEPRINT_RECEIVED
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model EmailEvent {
  id                String        @id @default(cuid())
  clientId          String?
  client            Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId            String?
  lead              Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template          EmailTemplate
  senderEmail       String?
  recipient         String
  provider          String        @default("resend")
  providerMessageId String?
  status            EmailStatus   @default(QUEUED)
  sentAt            DateTime?
  deliveredAt       DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime      @default(now())

  @@map("email_events")
}

